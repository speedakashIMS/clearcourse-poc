{
  "name": "@adobe/aem-boilerplate",
  "private": true,
  "version": "1.3.0",
  "description": "Starter project for Adobe Helix",
  "scripts": {
    "lint:js": "eslint \"blocks/**/*.{js,mjs,json}\" \"models/**/*.{js,mjs,json}\" \"scripts/**/*.{js,mjs,json}\" --ignore-pattern \"scripts/components/**\"",
    "lint:css": "stylelint \"blocks/**/*.css\" \"styles/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix",
    "lint:blocks": "eslint . --ext .json",
    "build:json": "npm-run-all -p build:json:models build:json:definitions build:json:filters",
    "build:json:models": "merge-json-cli -i \"models/_component-models.json\" -o \"component-models.json\"",
    "build:json:definitions": "merge-json-cli -i \"models/_component-definition.json\" -o \"component-definition.json\"",
    "build:json:filters": "merge-json-cli -i \"models/_component-filters.json\" -o \"component-filters.json\"",
    "block:create": "node create-block.js",
    "build:react-components": "npm --prefix react run build:components",
    "build:react-css": "npm --prefix react run build:css",
    "build:react-copy": "mkdir -p scripts/components styles && cp react/dist-components/*.js scripts/components/ && cp react/dist-css/styles.css styles/styles.css",
    "build:react-copy-window": "powershell -Command \"New-Item -ItemType Directory -Force -Path scripts/components,styles; Copy-Item react/dist-components/*.js scripts/components/; Copy-Item react/dist-css/styles.css styles/styles.css\"",
    "build:react": "npm run build:react-components && npm run build:react-css && npm run build:react-copy-window",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adobe/aem-boilerplate.git"
  },
  "author": "Adobe",
  "license": "Apache License 2.0",
  "bugs": {
    "url": "https://github.com/adobe/aem-boilerplate/issues"
  },
  "homepage": "https://github.com/adobe/aem-boilerplate#readme",
  "devDependencies": {
    "@babel/eslint-parser": "7.28.5",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-json": "3.1.0",
    "eslint-plugin-xwalk": "github:adobe-rnd/eslint-plugin-xwalk",
    "husky": "9.1.1",
    "merge-json-cli": "1.0.4",
    "npm-run-all": "4.1.5",
    "stylelint": "16.26.1",
    "stylelint-config-standard": "39.0.1"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
