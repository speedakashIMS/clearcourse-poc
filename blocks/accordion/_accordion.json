{
  "definitions": [
    {
      "title": "Accordion",
      "id": "accordion",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Accordion",
              "model": "accordion",
              "key-value": true,
              "filter": "accordion"
            }
          }
        }
      }
    },
    {
      "title": "AccordionListItem",
      "id": "accordionlistitem",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "AccordionListItem",
              "model": "accordionlistitem",
              "type": "accordionlistitem",
              "id": "id",
              "title": "title",
              "content": "content"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "accordion",
      "fields": [
        {
          "component": "text",
          "name": "id",
          "label": "Id",
          "valueType": "string"
        },
        {
          "component": "select",
          "name": "columns",
          "label": "Columns",
          "options": [
            { "name": "1", "value": "1" },
            { "name": "2", "value": "2" }
          ],
          "valueType": "string",
          "value": "1"
        },
        {
          "component": "select",
          "name": "width",
          "label": "Width",
          "options": [
            { "name": "full", "value": "full" },
            { "name": "constrained", "value": "constrained" }
          ],
          "valueType": "string",
          "value": "full",
          "condition": { "===": [{ "var": "columns" }, "1"] }
        },
        {
          "component": "select",
          "name": "colorVariant",
          "label": "Color Variant",
          "options": [
            { "name": "dark", "value": "dark" },
            { "name": "light", "value": "light" }
          ],
          "valueType": "string",
          "value": "dark"
        },
        {
          "component": "select",
          "name": "iconPosition",
          "label": "Icon Position",
          "options": [
            { "name": "left", "value": "left" },
            { "name": "right", "value": "right" }
          ],
          "valueType": "string",
          "value": "left"
        },
        {
          "component": "select",
          "name": "mediaPosition",
          "label": "Media Position",
          "options": [
            { "name": "left", "value": "left" },
            { "name": "right", "value": "right" }
          ],
          "valueType": "string",
          "value": "left",
          "condition": { "===": [{ "var": "columns" }, "2"] }
        },
        {
          "component": "text",
          "name": "mediaTitle",
          "label": "Media Alt Text",
          "valueType": "string",
          "condition": { "===": [{ "var": "columns" }, "2"] }
        },
        {
          "component": "select",
          "name": "mediaType",
          "label": "Media Type",
          "options": [
            { "name": "image", "value": "image" },
            { "name": "video", "value": "video" },
            { "name": "lottie", "value": "lottie" },
            { "name": "iframe", "value": "iframe" }
          ],
          "valueType": "string",
          "value": "image",
          "condition": { "===": [{ "var": "columns" }, "2"] }
        },
        {
          "component": "reference",
          "name": "imageUrl",
          "label": "Image",
          "valueType": "string",
          "value": "",
          "condition": {
            "and": [
              { "===": [{ "var": "columns" }, "2"] },
              { "===": [{ "var": "mediaType" }, "image"] }
            ]
          }
        },
        {
          "component": "text",
          "name": "iframeText",
          "label": "iframe Text",
          "valueType": "string",
          "value": "",
          "condition": {
            "and": [
              { "===": [{ "var": "columns" }, "2"] },
              { "===": [{ "var": "mediaType" }, "iframe"] }
            ]
          }
        },
        {
          "component": "select",
          "name": "videoType",
          "label": "Video Type",
          "options": [
            { "name": "upload", "value": "upload" },
            { "name": "external", "value": "external" }
          ],
          "valueType": "string",
          "value": "upload",
          "condition": {
            "and": [
              { "===": [{ "var": "columns" }, "2"] },
              { "===": [{ "var": "mediaType" }, "video"] }
            ]
          }
        },
        {
          "component": "reference",
          "name": "videoUpload",
          "label": "Video",
          "valueType": "string",
          "value": "",
          "condition": {
            "and": [
              { "===": [{ "var": "columns" }, "2"] },
              { "===": [{ "var": "mediaType" }, "video"] },
              { "===": [{ "var": "videoType" }, "upload"] }
            ]
          }
        },
        {
          "component": "text",
          "name": "videoExternal",
          "label": "Video",
          "valueType": "string",
          "value": "",
          "condition": {
            "and": [
              { "===": [{ "var": "columns" }, "2"] },
              { "===": [{ "var": "mediaType" }, "video"] },
              { "===": [{ "var": "videoType" }, "external"] }
            ]
          }
        },
        {
          "component": "select",
          "name": "lottieType",
          "label": "Lottie Type",
          "options": [
            { "name": "url", "value": "url" },
            { "name": "data", "value": "data" }
          ],
          "valueType": "string",
          "value": "data",
          "condition": {
            "and": [
              { "===": [{ "var": "columns" }, "2"] },
              { "===": [{ "var": "mediaType" }, "lottie"] }
            ]
          }
        },
        {
          "component": "text",
          "name": "lottieUrl",
          "label": "Lottie URL",
          "valueType": "string",
          "value": "",
          "condition": {
            "and": [
              { "===": [{ "var": "columns" }, "2"] },
              { "===": [{ "var": "mediaType" }, "lottie"] },
              { "===": [{ "var": "lottieType" }, "url"] }
            ]
          }
        },
        {
          "component": "text",
          "name": "lottieData",
          "label": "Lottie Data",
          "valueType": "string",
          "value": "",
          "condition": {
            "and": [
              { "===": [{ "var": "columns" }, "2"] },
              { "===": [{ "var": "mediaType" }, "lottie"] },
              { "===": [{ "var": "lottieType" }, "data"] }
            ]
          }
        },
        {
          "component": "boolean",
          "name": "schemaMarkup",
          "label": "Add FAQ Schema Markup",
          "valueType": "boolean",
          "value": false
        }
      ]
    },
    {
      "id": "accordionlistitem",
      "fields": [
        { "component": "text", "name": "type", "hidden": true },
        {
          "component": "container",
          "label": "Id",
          "name": "idContainer",
          "collapsible": false,
          "fields": [
            { "component": "text", "name": "id", "hidden": true },
            { "component": "text", "name": "idval", "valueType": "string" }
          ]
        },
        {
          "component": "container",
          "label": "Title",
          "name": "titleContainer",
          "collapsible": false,
          "fields": [
            { "component": "text", "name": "title", "hidden": true },
            { "component": "text", "name": "titleval", "valueType": "string" }
          ]
        },
        {
          "component": "container",
          "label": "Content",
          "name": "contentContainer",
          "collapsible": false,
          "fields": [
            { "component": "text", "name": "content", "hidden": true },
            {
              "component": "richtext",
              "name": "contentval",
              "valueType": "string"
            }
          ]
        }
