{
  "definitions": [
    {
      "title": "Section",
      "id": "section",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/section/v1/section",
            "template": {
              "model": "section"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "section",
      "fields": [
        {
          "component": "text",
          "name": "name",
          "label": "Section Name",
          "description": "The label shown for this section in the Content Tree"
        },
        {
          "component": "select",
          "name": "backgroundColor",
          "label": "Background Color",
          "options": [
            {
              "name": "Default",
              "value": "bg-default"
            },
            {
              "name": "Primary",
              "value": "bg-primary"
            },
            {
              "name": "Secondary",
              "value": "bg-secondary"
            },
            {
              "name": "Tertiary",
              "value": "bg-tertiary"
            },
            {
              "name": "Quarternary",
              "value": "bg-quarternary"
            },
            {
              "name": "White",
              "value": "bg-white"
            }
          ],
          "valueType": "string",
          "value": "bg-default"
        },
        {
          "component": "reference",
          "name": "backgroundImage",
          "label": "Background Image",
          "valueType": "boolean"
        },
        {
          "component": "boolean",
          "name": "negativeMargin",
          "label": "Negative Margin",
          "valueType": "boolean"
        },
        {
          "component": "boolean",
          "name": "backgroundGradient",
          "label": "Background Gradient",
          "valueType": "boolean"
        },
        {
          "component": "select",
          "name": "gradientType",
          "label": "Gradient",
          "options": [
            {
              "name": "HERO",
              "value": "bg-gradient-hero"
            },
            {
              "name": "Other",
              "value": "bg-gradient-2"
            }
          ],
          "valueType": "string",
          "value": "bg-gradient-hero",
          "condition": {
            "===": [
              {
                "var": "backgroundGradient"
              },
              true
            ]
          }
        },
        {
          "component": "select",
          "name": "containerDesktop",
          "label": "Container Width (Desktop)",
          "description": "Restrict the section width on desktop. 1100/700 centre the section on the page.",
          "options": [
            {
              "name": "Full",
              "value": "full"
            },
            {
              "name": "1100",
              "value": "1100"
            },
            {
              "name": "700",
              "value": "700"
            }
          ],
          "valueType": "string",
          "value": "full"
        },
        {
          "component": "select",
          "name": "containerMobile",
          "label": "Container Width (Mobile)",
          "description": "Restrict the section width on mobile. 1100/700 centre the section on the page.",
          "options": [
            {
              "name": "Full",
              "value": "full"
            },
            {
              "name": "1100",
              "value": "1100"
            },
            {
              "name": "700",
              "value": "700"
            }
          ],
          "valueType": "string",
          "value": "full"
        },
        {
          "component": "select",
          "name": "paddingDesktop",
          "label": "Horizontal Padding (Desktop)",
          "description": "Adds left/right padding to the section on desktop.",
          "options": [
            {
              "name": "None",
              "value": "none"
            },
            {
              "name": "p-50",
              "value": "50"
            },
            {
              "name": "p-100",
              "value": "100"
            },
            {
              "name": "p-200",
              "value": "200"
            },
            {
              "name": "p-300",
              "value": "300"
            },
            {
              "name": "p-500",
              "value": "500"
            }
          ],
          "valueType": "string",
          "value": "none"
        },
        {
          "component": "select",
          "name": "paddingDesktopVertical",
          "label": "Vertical Padding (Desktop)",
          "description": "Adds top/bottom padding to the section on desktop.",
          "options": [
            {
              "name": "None",
              "value": "none"
            },
            {
              "name": "p-50",
              "value": "50"
            },
            {
              "name": "p-100",
              "value": "100"
            },
            {
              "name": "p-200",
              "value": "200"
            },
            {
              "name": "p-300",
              "value": "300"
            },
            {
              "name": "p-500",
              "value": "500"
            }
          ],
          "valueType": "string",
          "value": "none"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "section",
      "components": [
        "accordion",
        "awardscards",
        "awardsmedia",
        "breadcrumbs",
        "buttons",
        "cardsicon",
        "cardsimage",
        "cta",
        "downloads",
        "eventandwebinar",
        "footer",
        "giftprocardandtext",
        "form",
        "hero",
        "heroarticle",
        "herobackgroundimage",
        "introductionheader",
        "logos",
        "maplocations",
        "mapwithinfo",
        "media",
        "navigationsimple",
        "newsgrid",
        "richtext",
        "secondaryinfo",
        "spacer",
        "statscolumns",
        "statswithmedia",
        "statswithtestimonials",
        "table",
        "testimonials",
        "trust",
        "textandmedia",
        "tiles",
        "video"
      ]
    }
  ]
}
